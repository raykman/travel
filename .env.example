# Copy to .env and fill in real values for local dev.
# In production these live in Cloudflare Pages → Settings → Environment Variables.

# Mapbox — public, exposed in client JS
PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Notion — build-time only, never exposed to client
NOTION_API_KEY=ntn_your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
