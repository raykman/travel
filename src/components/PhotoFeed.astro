---
import type { Post } from '../lib/posts';
import PhotoCard from './PhotoCard.astro';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

// PhotoCard requires at least one image
const withImages = posts.filter((p) => p.data.images.length > 0);
---

{withImages.length > 0 && (
  <section class="feed" aria-labelledby="feed-heading">
    <h2 id="feed-heading" class="feed-heading glass">Field notes</h2>

    <div class="feed-list">
      {withImages.map((post, i) => (
        <PhotoCard
          day={post.data.day}
          location={post.data.location}
          title={post.data.title}
          caption={post.body.trim()}
          images={post.data.images}
          index={i}
          country={post.data.country}
          coordinates={post.data.coordinates}
        />
      ))}
    </div>
  </section>
)}

<style>
  /* Full-width — intentionally no .container wrapper; PhotoCard handles
     the full-bleed images and constrains caption text itself. */
  .feed {
    display: flex;
    flex-direction: column;
  }

  .feed-heading {
    /* Glass pill label above the feed */
    display: inline-block;
    align-self: center;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    margin: 0 0 32px;
    padding: 8px 16px;
    border-radius: 999px; /* pill shape */
  }

  .feed-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
</style>
