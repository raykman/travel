---
import { getAllPosts, type Post } from '../lib/posts';
import PhotoCard from './PhotoCard.astro';

const posts = await getAllPosts(); // already sorted newest-first

// PhotoCard requires at least one image, so filter out imageless posts
// (can happen with Notion entries that omit the Image URL field).
const withImages: Post[] = posts.filter((p) => p.data.images.length > 0);
---

<section class="feed container section" aria-labelledby="feed-heading">
  <h2 id="feed-heading" class="label-lg feed-heading">Field notes</h2>

  {withImages.length === 0 ? (
    <p class="feed-empty text-tertiary">No entries yet.</p>
  ) : (
    <div class="feed-list">
      {withImages.map((post, i) => (
        <PhotoCard
          day={post.data.day}
          location={post.data.location}
          title={post.data.title}
          caption={post.body.trim()}
          images={post.data.images}
          index={i}
          country={post.data.country}
        />
      ))}
    </div>
  )}
</section>

<style>
  .feed-heading {
    margin: 0 0 24px;
    display: block;
  }

  .feed-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .feed-empty {
    font-size: 13px;
    margin: 0;
  }
</style>
