---
import { getDaysUntilStart, TRIP_START } from '../lib/dates';

// Server-side value — used as the initial render, then immediately
// overwritten by the client script so stale static builds stay accurate.
const days = getDaysUntilStart();

const startLabel = TRIP_START.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<section
  class="countdown glass"
  aria-label="Countdown to trip"
  data-trip-start={TRIP_START.getTime().toString()}
>
  <span class="label countdown-label">Departing in</span>
  <p class="countdown-number">
    <span id="countdown-days">{days}</span>
    <span id="countdown-unit" class="countdown-unit">{days === 1 ? 'day' : 'days'}</span>
  </p>
  <span class="countdown-date">{startLabel}</span>
</section>

<script>
  // Recalculate on every page load so the number is always correct
  // regardless of when the static build ran.
  (function () {
    const section = document.querySelector<HTMLElement>('[data-trip-start]');
    if (!section) return;
    const tripStartMs = parseInt(section.dataset.tripStart ?? '0', 10);

    function daysRemaining(): number {
      const now = new Date();
      const todayMidnight = Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate());
      const d = new Date(tripStartMs);
      const startMidnight = Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
      const wholeDays = Math.round((startMidnight - todayMidnight) / 86_400_000);
      return Math.max(0, wholeDays + 1); // inclusive of today and departure day
    }

    const daysEl = document.getElementById('countdown-days');
    const unitEl = document.getElementById('countdown-unit');
    if (!daysEl || !unitEl) return;

    const d = daysRemaining();
    daysEl.textContent = String(d);
    unitEl.textContent = d === 1 ? 'day' : 'days';
  })();
</script>

<style>
  .countdown {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 36px 32px;
    text-align: center;
  }

  .countdown-label {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .countdown-number {
    font-size: clamp(72px, 18vw, 120px);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0;
    color: var(--text);
  }

  .countdown-unit {
    font-size: 0.22em;
    font-weight: 400;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-left: 10px;
    vertical-align: middle;
  }

  .countdown-date {
    display: block;
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
  }
</style>
