---
import countries from '../data/countries.json';
import { TRIP_LENGTH_DAYS } from '../lib/dates';

interface Props {
  currentDay: number; // 1..62 (0 means nothing filled)
}

const { currentDay } = Astro.props;

// Build segments: one per country, width proportional to days in that country.
const segments = countries.map((c) => {
  const days = c.endDay - c.startDay + 1;
  const widthPct = (days / TRIP_LENGTH_DAYS) * 100;

  // How much of this segment is "filled" by the current day?
  let fillPct = 0;
  if (currentDay >= c.endDay) fillPct = 100;
  else if (currentDay >= c.startDay) {
    fillPct = ((currentDay - c.startDay + 1) / days) * 100;
  }

  return {
    id: c.id,
    name: c.name,
    color: c.color,
    widthPct,
    fillPct,
  };
});
---

<section class="progress container" aria-label="Trip progress">
  <div class="progress-bar" role="img" aria-label={`Day ${currentDay}`}>
    {segments.map((s) => (
      <div
        class="segment"
        style={`width: ${s.widthPct}%; --seg-color: ${s.color};`}
      >
        <div class="segment-fill" style={`width: ${s.fillPct}%;`}></div>
      </div>
    ))}
  </div>
  <div class="progress-labels">
    {segments.map((s) => (
      <span class="label country-label" style={`color: ${s.color};`}>
        {s.name}
      </span>
    ))}
  </div>
</section>

<style>
  .progress {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 32px;
  }

  .progress-bar {
    display: flex;
    width: 100%;
    height: 4px;
    border-radius: 2px;
    overflow: hidden;
    background: var(--surface);
    gap: 2px;
  }

  .segment {
    position: relative;
    height: 100%;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .segment-fill {
    height: 100%;
    background: var(--seg-color);
    transition: width 1s ease;
  }

  .progress-labels {
    display: flex;
    justify-content: space-between;
    gap: 8px;
  }

  .country-label {
    font-size: 9px;
    opacity: 0.85;
  }

  @media (max-width: 380px) {
    .progress-labels {
      display: none;
    }
  }

  @media (min-width: 640px) {
    .country-label {
      font-size: 10px;
    }
  }
</style>
