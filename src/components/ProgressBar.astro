---
import countries from '../data/countries.json';
import { TRIP_LENGTH_DAYS } from '../lib/dates';

interface Props {
  currentDay: number;
}

const { currentDay } = Astro.props;

const segments = countries.map((c) => {
  const days = c.endDay - c.startDay + 1;
  const widthPct = (days / TRIP_LENGTH_DAYS) * 100;

  let fillPct = 0;
  if (currentDay >= c.endDay) fillPct = 100;
  else if (currentDay >= c.startDay) {
    fillPct = ((currentDay - c.startDay + 1) / days) * 100;
  }

  return { id: c.id, name: c.name, color: c.color, widthPct, fillPct };
});
---

<section class="progress glass" aria-label="Trip progress">
  <div class="progress-bar" role="img" aria-label={`Day ${currentDay} of ${TRIP_LENGTH_DAYS}`}>
    {segments.map((s) => (
      <div
        class="segment"
        style={`width: ${s.widthPct}%; --seg-color: ${s.color};`}
      >
        <div class="segment-fill" style={`width: ${s.fillPct}%;`}></div>
      </div>
    ))}
  </div>
  <div class="progress-labels">
    {segments.map((s) => (
      <span class="country-label" style={`color: ${s.color};`}>
        {s.name}
      </span>
    ))}
  </div>
</section>

<style>
  .progress {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 20px;
  }

  .progress-bar {
    display: flex;
    width: 100%;
    height: 3px;
    border-radius: 2px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.06);
    gap: 2px;
  }

  .segment {
    position: relative;
    height: 100%;
    background: rgba(255, 255, 255, 0.10);
    border-radius: 2px;
    overflow: hidden;
  }

  .segment-fill {
    height: 100%;
    background: var(--seg-color);
    transition: width 1s ease;
  }

  .progress-labels {
    display: flex;
    justify-content: space-between;
    gap: 8px;
  }

  .country-label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    opacity: 0.80;
  }

  @media (max-width: 380px) {
    .progress-labels {
      display: none;
    }
  }

  @media (min-width: 640px) {
    .country-label {
      font-size: 10px;
    }
  }
</style>
