---
// Client-side password gate.
// Password is stored as a SHA-256 hex digest so the plaintext doesn't ship in JS.
// To change the password: hash your new password with SHA-256 and paste the hex
// below (you can use: `echo -n "yourpassword" | shasum -a 256`)
//
// SHA-256 of "welcome"
const PASSWORD_HASH =
  '280d44ab1e9f79b5cce2dd4f58f5fe91f0fbacdac9f7447dffc318ceb79f2d02';
---

<div id="password-gate" class="gate" role="dialog" aria-modal="true" aria-label="Password required" aria-describedby="gate-subtitle" aria-hidden="false">
  <div class="gate-inner">
    <h1 class="gate-title">Where Is Ray</h1>
    <p class="gate-subtitle" id="gate-subtitle">japan · southeast asia · 2026</p>
    <form id="password-form" class="gate-form" autocomplete="off" novalidate>
      <div id="password-wrap" class="gate-input-wrap">
        <input
          id="password-input"
          type="password"
          name="password"
          placeholder="password"
          aria-label="Password"
          autocomplete="off"
          autocapitalize="off"
          autocorrect="off"
          spellcheck="false"
        />
      </div>
      <button type="submit" class="gate-button">enter</button>
    </form>
  </div>
</div>

<style>
  .gate {
    position: fixed;
    inset: 0;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--content-pad);
    z-index: 100;
  }

  .gate[hidden] {
    display: none;
  }

  .gate-inner {
    width: 100%;
    max-width: 280px;
    text-align: center;
  }

  .gate-title {
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .gate-subtitle {
    font-size: 13px;
    color: var(--text-tertiary);
    margin: 8px 0 40px;
    letter-spacing: 0.04em;
  }

  .gate-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .gate-input-wrap {
    /* wrapper so we can shake without affecting form layout */
  }

  .gate-input-wrap.shake {
    animation: shake 400ms ease;
  }

  #password-input {
    width: 100%;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-input);
    color: var(--text);
    font-size: 14px;
    letter-spacing: 0.1em;
    text-align: center;
    outline: none;
    transition: border-color 200ms ease;
  }

  #password-input::placeholder {
    color: var(--text-tertiary);
    letter-spacing: 0.1em;
  }

  #password-input:focus {
    border-color: var(--text-secondary);
  }

  .gate-button {
    width: 100%;
    padding: 14px 16px;
    background: var(--text);
    color: var(--bg);
    border-radius: var(--radius-input);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    transition: opacity 150ms ease;
  }

  .gate-button:hover {
    opacity: 0.9;
  }

  .gate-button:active {
    opacity: 0.8;
  }

  @keyframes shake {
    0%,
    100% {
      transform: translateX(0);
    }
    20% {
      transform: translateX(-8px);
    }
    40% {
      transform: translateX(8px);
    }
    60% {
      transform: translateX(-6px);
    }
    80% {
      transform: translateX(6px);
    }
  }
</style>

<script is:inline define:vars={{ PASSWORD_HASH }}>
  (function () {
    const STORAGE_KEY = 'whereisray_auth';
    const gate = document.getElementById('password-gate');
    const form = document.getElementById('password-form');
    const input = document.getElementById('password-input');
    const wrap = document.getElementById('password-wrap');
    if (!gate || !form || !input || !wrap) return;

    // Already authed? Skip gate entirely.
    try {
      if (localStorage.getItem(STORAGE_KEY) === 'true') {
        gate.setAttribute('hidden', '');
        return;
      }
    } catch (_) {
      /* private mode — fall through, show gate */
    }

    // Focus input on first interactive paint.
    requestAnimationFrame(() => input.focus());

    async function sha256Hex(str) {
      const buf = new TextEncoder().encode(str);
      const digest = await crypto.subtle.digest('SHA-256', buf);
      return Array.from(new Uint8Array(digest))
        .map((b) => b.toString(16).padStart(2, '0'))
        .join('');
    }

    // Focus trap: keep keyboard navigation inside the gate while visible
    gate.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const focusable = gate.querySelectorAll('input, button');
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const value = input.value;
      if (!value) return;
      const hash = await sha256Hex(value);
      if (hash === PASSWORD_HASH) {
        try {
          localStorage.setItem(STORAGE_KEY, 'true');
        } catch (_) {
          /* ignore */
        }
        gate.setAttribute('hidden', '');
      } else {
        wrap.classList.remove('shake');
        // force reflow so animation restarts on repeated failures
        void wrap.offsetWidth;
        wrap.classList.add('shake');
        input.value = '';
        input.focus();
      }
    });
  })();
</script>
