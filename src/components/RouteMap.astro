---
import routeData from '../data/route.json';

interface Props {
  currentCoordinates?: [number, number] | null; // [lat, lng] from latest post
  currentDay?: number;
}

const { currentCoordinates = null, currentDay = 0 } = Astro.props;

const MAPBOX_TOKEN = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

// Convert [lat, lng] (post convention) to [lng, lat] (GeoJSON/Mapbox convention)
const currentLngLat = currentCoordinates
  ? [currentCoordinates[1], currentCoordinates[0]]
  : null;

const mapConfig = {
  token: MAPBOX_TOKEN,
  routeData,
  currentLngLat,
  currentDay,
};
---

<!--
  Full-bleed map base layer.
  position: fixed, z-index: 0 — sits behind the .scroll-layer (z: 10).
  interactive: false on the Mapbox instance — flyTo works programmatically
  (driven by scrollytelling) but users cannot drag/zoom the map; page scrolls
  over it normally.

  OPTION B scaffold: to revert to a contained map on mobile, apply this CSS:
    @media (max-width: 767px) {
      .map-base { position: relative; height: 55vw; min-height: 280px; }
    }
  and in the script set `interactive: true` on mobile.
-->
<div
  class="map-base"
  role="img"
  aria-label="Interactive route map showing travel path through Japan, Vietnam, Cambodia, Laos, and Indonesia"
>
  <p class="sr-only">Route: Tokyo, Niigata, Sapporo, Kobe, Okinawa, Hanoi, Hoi An, Ho Chi Minh City, Siem Reap, Phnom Penh, Luang Prabang, Thakhek, Jakarta, Yogyakarta, Surabaya, Pangkalan Bun</p>
  <div id="route-map" class="map"></div>
  <script
    type="application/json"
    id="route-map-config"
    set:html={JSON.stringify(mapConfig)}
  />
</div>

<!-- Map control buttons — position: fixed, z: 20, right side of viewport -->
<div class="map-controls">
  <!-- Reset view: fly to full route -->
  <button
    id="map-reset"
    class="map-ctrl-btn"
    type="button"
    aria-label="Reset map to show full route"
    title="Reset view"
  >
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M12.5 2.5 A6 6 0 1 0 13 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/>
      <path d="M10 0.5 L13 2.5 L10.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  </button>

  <!-- Interaction toggle: lock / unlock map drag & zoom -->
  <button
    id="map-interact-toggle"
    class="map-ctrl-btn"
    type="button"
    aria-pressed="false"
    aria-label="Lock map"
    title="Lock map (disable drag & zoom)"
  >
    <!-- Lock icon (default: interaction off) -->
    <svg class="icon-locked" width="13" height="14" viewBox="0 0 13 14" fill="none" aria-hidden="true">
      <rect x="1" y="6" width="11" height="8" rx="2" stroke="currentColor" stroke-width="1.4"/>
      <path d="M3.5 6V4a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    <!-- Unlock icon (interaction on) -->
    <svg class="icon-unlocked" width="13" height="14" viewBox="0 0 13 14" fill="none" aria-hidden="true">
      <rect x="1" y="6" width="11" height="8" rx="2" stroke="currentColor" stroke-width="1.4"/>
      <path d="M3.5 6V4a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
  </button>
</div>

<style>
  /* ---- Base layer: fixed full-viewport map ---- */
  .map-base {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    /* pointer-events: none so the scroll-layer above captures all user
       events. flyTo/fitBounds still work because they're programmatic. */
    pointer-events: none;
  }

  .map {
    width: 100%;
    height: 100%;
  }

  /* ---- Map control button group ---- */
  .map-controls {
    position: fixed;
    bottom: calc(20px + env(safe-area-inset-bottom, 0px));
    right: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    pointer-events: auto; /* override parent's none */
    z-index: 20;
  }

  .map-ctrl-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(20, 20, 20, 0.72);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 50%;
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 150ms ease, background 150ms ease;
  }

  .map-ctrl-btn:hover {
    color: var(--text);
    background: rgba(35, 35, 35, 0.88);
  }

  /* Interaction toggle: accent color when active (unlocked) */
  .map-ctrl-btn[aria-pressed='true'] {
    color: var(--accent);
    border-color: rgba(184, 168, 138, 0.30);
  }

  /* Swap lock/unlock icons */
  .icon-unlocked { display: none; }
  .map-ctrl-btn[aria-pressed='true'] .icon-locked   { display: none; }
  .map-ctrl-btn[aria-pressed='true'] .icon-unlocked { display: block; }

  /* ---- Map city labels (HTML Markers) ---- */
  :global(.map-city-label) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    /* pointer-events: auto so hover highlights the matching upcoming item */
    pointer-events: auto;
    cursor: default;
    color: var(--text-tertiary);
    text-shadow:
      0 0 3px rgba(16, 16, 15, 0.95),
      0 0 10px rgba(16, 16, 15, 0.8);
    transition: color 150ms ease;
  }

  :global(.map-city-label:hover),
  :global(.map-city-label.is-hover-active) {
    color: var(--text) !important;
  }

  :global(.map-city-label.visited) {
    color: var(--accent);
  }

  :global(.map-city-label.current) {
    color: var(--text);
    font-weight: 500;
  }

  /* ---- Current-location pulsing marker ---- */
  :global(.map-current-marker) {
    width: 14px;
    height: 14px;
    pointer-events: none;
  }

  :global(.map-current-dot) {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--accent);
    animation: map-pulse 3s ease-in-out infinite;
  }

  @keyframes map-pulse {
    0%,
    100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(184, 168, 138, 0.35);
    }
    50% {
      transform: scale(1.35);
      box-shadow: 0 0 0 8px rgba(184, 168, 138, 0.04);
    }
  }

  :global(.mapboxgl-ctrl-logo),
  :global(.mapboxgl-ctrl-attrib) {
    opacity: 0.25;
  }
</style>

<script>
  import mapboxgl from 'mapbox-gl';

  (async function () {
    const mapEl = document.getElementById('route-map');
    const resetBtn = document.getElementById('map-reset');
    const interactToggle = document.getElementById('map-interact-toggle');
    const configEl = document.getElementById('route-map-config');
    if (!mapEl || !configEl) return;

    let cfg: any;
    try {
      cfg = JSON.parse(configEl.textContent || '{}');
    } catch (e) {
      console.error('[RouteMap] failed to parse config', e);
      return;
    }
    const { token: MAPBOX_TOKEN, routeData, currentLngLat, currentDay } = cfg;

    if (!MAPBOX_TOKEN) {
      mapEl.innerHTML =
        '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-tertiary);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;">Map token not set</div>';
      return;
    }

    mapboxgl.accessToken = MAPBOX_TOKEN;

    // ---- Route data helpers ----
    const departurePoint = routeData.features.find(
      (f: any) => f.geometry.type === 'Point' && f.properties.departure
    );
    const points = routeData.features.filter(
      (f: any) => f.geometry.type === 'Point' && !f.properties.departure
    );
    const routeFeatureByName = (name: string) =>
      routeData.features.find(
        (f: any) => f.geometry.type === 'LineString' && f.properties.name === name
      );

    const allBounds = new mapboxgl.LngLatBounds();
    points.forEach((p: any) => allBounds.extend(p.geometry.coordinates));

    // ---- Snap current position to nearest route stop ----
    // Post days and route-stop days are independent integers and often don't
    // match (e.g. post written on day 4 while the Niigata stop is day 5).
    // Using the post day directly as the visited/future boundary leaves the
    // pulsing marker at Niigata but the gold line ending one stop too early.
    //
    // Fix: when we have a real current location (live trip, posts exist),
    // find the geographically nearest route stop and use ITS day as the
    // effective boundary — so the gold line always ends at the same stop
    // the pulsing dot sits on.
    let effectiveDay = currentDay;
    if (currentLngLat && currentDay > 0) {
      const [curLng, curLat] = currentLngLat as [number, number];
      let minDist = Infinity;
      for (const p of points as any[]) {
        const [lng, lat] = p.geometry.coordinates as [number, number];
        const dist = (lng - curLng) ** 2 + (lat - curLat) ** 2;
        if (dist < minDist) { minDist = dist; effectiveDay = p.properties.day; }
      }
    }

    const DAY_RANGE = 20;
    const nearbyPoints = effectiveDay
      ? points.filter(
          (p: any) =>
            p.properties.day >= effectiveDay - DAY_RANGE &&
            p.properties.day <= effectiveDay + DAY_RANGE
        )
      : points;
    const initialBounds = new mapboxgl.LngLatBounds();
    nearbyPoints.forEach((p: any) => initialBounds.extend(p.geometry.coordinates));

    // ---- Map init ----
    // interactive: true — map is freely scrollable/draggable by default.
    // The lock button in the controls disables interaction when pressed.
    const map = new mapboxgl.Map({
      container: mapEl,
      style: 'mapbox://styles/mapbox/dark-v11',
      bounds: initialBounds.isEmpty() ? allBounds : initialBounds,
      fitBoundsOptions: { padding: 100, duration: 0 },
      interactive: true,
      attributionControl: true,
    });

    // Expose for scrollytelling + reset button
    (window as any).__map = map;
    (window as any).__mapAllBounds = allBounds;

    // ---- Layer setup ----
    const onLoad = () => {
      // Override base colors to match deep charcoal theme
      try {
        if (map.getLayer('background')) {
          map.setPaintProperty('background', 'background-color', '#10100F');
        }
        const waterLayers = map.getStyle().layers.filter((l: any) => l.id.includes('water'));
        waterLayers.forEach((l: any) => {
          if (l.type === 'fill') {
            try { map.setPaintProperty(l.id, 'fill-color', '#181818'); } catch (_) {}
          }
        });
        const labelLayers = map.getStyle().layers.filter((l: any) => l.type === 'symbol');
        labelLayers.forEach((l: any) => {
          try { map.setLayoutProperty(l.id, 'visibility', 'none'); } catch (_) {}
        });
      } catch (_) { /* style overrides are best-effort */ }

      // ---- Departure flight arc (SF → Tokyo) — smooth great-circle ----
      // Generate a true great-circle arc with 80 segments so the curved path
      // has no visible kinks. Longitudes are "unwrapped" past the antimeridian
      // so Mapbox renders a continuous westward arc rather than jumping to +140.
      function greatCircleArc(
        start: [number, number],
        end: [number, number],
        numPts = 80
      ): [number, number][] {
        const D2R = Math.PI / 180;
        const R2D = 180 / Math.PI;
        const [lng1, lat1] = [start[0] * D2R, start[1] * D2R];
        const [lng2, lat2] = [end[0] * D2R,   end[1] * D2R  ];
        const x1 = Math.cos(lat1) * Math.cos(lng1), y1 = Math.cos(lat1) * Math.sin(lng1), z1 = Math.sin(lat1);
        const x2 = Math.cos(lat2) * Math.cos(lng2), y2 = Math.cos(lat2) * Math.sin(lng2), z2 = Math.sin(lat2);
        const dot = Math.min(1, Math.max(-1, x1*x2 + y1*y2 + z1*z2));
        const theta = Math.acos(dot);
        const sinT = Math.sin(theta);
        const pts: [number, number][] = [];
        let prevLng = start[0];
        for (let i = 0; i <= numPts; i++) {
          const t = i / numPts;
          let x: number, y: number, z: number;
          if (sinT < 1e-10) { x = x1; y = y1; z = z1; }
          else {
            const A = Math.sin((1 - t) * theta) / sinT;
            const B = Math.sin(t * theta) / sinT;
            x = A*x1 + B*x2; y = A*y1 + B*y2; z = A*z1 + B*z2;
          }
          const lat = Math.atan2(z, Math.sqrt(x*x + y*y)) * R2D;
          let lng  = Math.atan2(y, x) * R2D;
          // Unwrap: keep longitude continuous (no ±180 jumps)
          while (lng - prevLng >  180) lng -= 360;
          while (lng - prevLng < -180) lng += 360;
          pts.push([lng, lat]);
          prevLng = lng;
        }
        return pts;
      }

      const flightIsVisited = currentDay > 0;
      const firstStop = [...points].sort((a: any, b: any) => a.properties.day - b.properties.day)[0];

      if (departurePoint && firstStop) {
        const arcCoords = greatCircleArc(
          departurePoint.geometry.coordinates as [number, number],
          firstStop.geometry.coordinates   as [number, number],
          80
        );
        const arcFeature = {
          type: 'Feature' as const,
          properties: {},
          geometry: { type: 'LineString' as const, coordinates: arcCoords },
        };

        map.addSource('departure-flight', { type: 'geojson', data: arcFeature });
        map.addLayer({
          id: 'departure-flight',
          type: 'line',
          source: 'departure-flight',
          paint: flightIsVisited
            ? { 'line-color': '#B8A88A', 'line-width': 2, 'line-dasharray': [0.001, 5000] }
            : { 'line-color': '#505258', 'line-width': 1.8, 'line-dasharray': [3, 3] },
        });

        if (flightIsVisited) {
          const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!prefersReduced) {
            const DASH_MAX = 5000;
            const DURATION = 3000;
            const startTime = performance.now();
            function animateFlight(now: number) {
              const t = Math.min((now - startTime) / DURATION, 1);
              const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
              const drawn = Math.max(DASH_MAX * ease, 0.001);
              const gap   = Math.max(DASH_MAX - drawn, 0.001);
              try { map.setPaintProperty('departure-flight', 'line-dasharray', [drawn, gap]); } catch (_) {}
              if (t < 1) requestAnimationFrame(animateFlight);
            }
            requestAnimationFrame(animateFlight);
          } else {
            try { map.setPaintProperty('departure-flight', 'line-dasharray', [5000, 0]); } catch (_) {}
          }
        }
      }

      // Departure city dot + label
      if (departurePoint) {
        map.addSource('stop-departure', {
          type: 'geojson',
          data: { type: 'FeatureCollection', features: [departurePoint] },
        });
        map.addLayer({
          id: 'stop-departure',
          type: 'circle',
          source: 'stop-departure',
          paint: flightIsVisited
            ? { 'circle-radius': 4, 'circle-color': '#B8A88A', 'circle-opacity': 0.75 }
            : { 'circle-radius': 4, 'circle-color': 'rgba(0,0,0,0)', 'circle-stroke-color': '#505258', 'circle-stroke-width': 1.4 },
        });
        const depLabel = document.createElement('span');
        depLabel.className = 'map-city-label';
        depLabel.textContent = departurePoint.properties.city;
        new mapboxgl.Marker({ element: depLabel, anchor: 'left', offset: [8, 0] })
          .setLngLat(departurePoint.geometry.coordinates)
          .addTo(map);
      }

      // ---- Route lines ----
      // Two separate sources keep future (dotted gray) and visited (solid gold)
      // visually distinct at all times — no shared layer that could bleed gold
      // onto future segments.
      const visited = points.filter((p: any) => p.properties.day <= effectiveDay);
      const future  = points.filter((p: any) => p.properties.day > effectiveDay);

      const byDay = (a: any, b: any) => a.properties.day - b.properties.day;
      const visitedCoords = [...visited].sort(byDay).map((f: any) => f.geometry.coordinates);
      const futureCoords  = [...future ].sort(byDay).map((f: any) => f.geometry.coordinates);

      // Future dotted line — bridge from the last visited stop so there's no gap
      const futureLine: [number, number][] = visitedCoords.length > 0
        ? [visitedCoords[visitedCoords.length - 1], ...futureCoords]
        : [...points].sort(byDay).map((f: any) => f.geometry.coordinates);

      if (futureLine.length > 1) {
        map.addSource('route-future', {
          type: 'geojson',
          data: { type: 'Feature', properties: {}, geometry: { type: 'LineString', coordinates: futureLine } },
        });
        map.addLayer({
          id: 'route-future',
          type: 'line',
          source: 'route-future',
          paint: { 'line-color': '#505258', 'line-width': 1.8, 'line-dasharray': [3, 3] },
        });
      }

      // Visited solid gold line — animated draw-in
      if (visitedCoords.length > 1) {
        map.addSource('route-visited', {
          type: 'geojson',
          data: { type: 'Feature', properties: {}, geometry: { type: 'LineString', coordinates: visitedCoords } },
        });
        map.addLayer({
          id: 'route-visited',
          type: 'line',
          source: 'route-visited',
          paint: { 'line-color': '#B8A88A', 'line-width': 2, 'line-dasharray': [0.001, 5000] },
        });

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!prefersReduced) {
          const DASH_MAX = 5000;
          const DURATION = 3000;
          const startTime = performance.now();
          function animateRoute(now: number) {
            const t = Math.min((now - startTime) / DURATION, 1);
            const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
            const drawn = Math.max(DASH_MAX * ease, 0.001);
            const gap   = Math.max(DASH_MAX - drawn, 0.001);
            try { map.setPaintProperty('route-visited', 'line-dasharray', [drawn, gap]); } catch (_) {}
            if (t < 1) requestAnimationFrame(animateRoute);
          }
          requestAnimationFrame(animateRoute);
        } else {
          try { map.setPaintProperty('route-visited', 'line-dasharray', [5000, 0]); } catch (_) {}
        }
      }

      // ---- Stop dots ----
      if (future.length) {
        map.addSource('stops-future', { type: 'geojson', data: { type: 'FeatureCollection', features: future } });
        map.addLayer({
          id: 'stops-future', type: 'circle', source: 'stops-future',
          paint: { 'circle-radius': 4, 'circle-color': 'rgba(0,0,0,0)', 'circle-stroke-color': '#505258', 'circle-stroke-width': 1.4 },
        });
      }

      if (visited.length) {
        map.addSource('stops-visited', { type: 'geojson', data: { type: 'FeatureCollection', features: visited } });
        map.addLayer({
          id: 'stops-visited', type: 'circle', source: 'stops-visited',
          paint: { 'circle-radius': 4, 'circle-color': '#B8A88A', 'circle-opacity': 0.75 },
        });
      }

      // ---- Current location pulsing marker ----
      if (currentLngLat) {
        const wrap = document.createElement('div');
        wrap.className = 'map-current-marker';
        const inner = document.createElement('div');
        inner.className = 'map-current-dot';
        wrap.appendChild(inner);
        new mapboxgl.Marker({ element: wrap, anchor: 'center' })
          .setLngLat(currentLngLat)
          .addTo(map);
      }

      // ---- City name labels ----
      // pointer-events: auto (see CSS) so hovering dispatches 'cityhover'
      // to highlight the matching upcoming item in the sidebar.
      points.forEach((p: any) => {
        const city = p.properties?.city;
        if (!city) return;
        const day = p.properties.day;
        const label = document.createElement('span');
        label.className = 'map-city-label';
        label.dataset.day = String(day);
        if (typeof day === 'number') {
          if (day < effectiveDay)  label.classList.add('visited');
          else if (day === effectiveDay) label.classList.add('current');
        }
        label.textContent = city;

        label.addEventListener('mouseenter', () => {
          document.dispatchEvent(new CustomEvent('cityhover', { detail: { day } }));
        });
        label.addEventListener('mouseleave', () => {
          document.dispatchEvent(new CustomEvent('cityhover', { detail: { day: null } }));
        });

        new mapboxgl.Marker({ element: label, anchor: 'left', offset: [8, 0] })
          .setLngLat(p.geometry.coordinates)
          .addTo(map);
      });

      // Signal readiness for scrollytelling
      document.dispatchEvent(new CustomEvent('mapready'));
    };

    if (map.isStyleLoaded()) {
      onLoad();
    } else {
      map.on('load', onLoad);
    }

    // ---- Reset-view button ----
    resetBtn?.addEventListener('click', () => {
      const b = allBounds.isEmpty() ? null : allBounds;
      if (b) {
        map.flyTo({
          ...map.cameraForBounds(b, { padding: 100 })!,
          duration: 1400,
          essential: true,
        });
      }
    });

    // ---- Map interaction toggle ----
    // Default: interactive (drag/scroll/zoom freely).
    // Lock button disables interaction so the page/sidebar can scroll unimpeded.
    let isInteractive = true;

    function setMapInteractive(on: boolean) {
      isInteractive = on;
      const handlers = [
        map.scrollZoom, map.dragPan, map.dragRotate,
        map.touchZoomRotate, map.doubleClickZoom, map.keyboard,
      ];
      handlers.forEach((h) => { try { on ? h.enable() : h.disable(); } catch (_) {} });

      // pointer-events: none on .map-base blocks all canvas input;
      // must mirror the interactive state or drag/scroll never reach Mapbox.
      // mapEl is guaranteed non-null here (guarded at IIFE entry), but TS
      // can't track that through the closure — non-null assertion is safe.
      const mapBase = mapEl!.parentElement as HTMLElement | null;
      if (mapBase) mapBase.style.pointerEvents = on ? 'auto' : 'none';

      // aria-pressed = true means the map is LOCKED (interaction off)
      interactToggle?.setAttribute('aria-pressed', String(!on));
      interactToggle?.setAttribute(
        'aria-label', on ? 'Lock map' : 'Unlock map'
      );
      interactToggle?.setAttribute(
        'title', on ? 'Lock map (disable drag & zoom)' : 'Unlock map (enable drag & zoom)'
      );

      if (mapEl) mapEl.style.cursor = on ? 'grab' : '';
    }

    // Start interactive (belt-and-suspenders alongside interactive: true)
    setMapInteractive(true);

    interactToggle?.addEventListener('click', () => setMapInteractive(!isInteractive));
  })();
</script>
