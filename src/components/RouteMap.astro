---
import routeData from '../data/route.json';

interface Props {
  currentCoordinates?: [number, number] | null; // [lat, lng] from latest post
  currentDay?: number;
}

const { currentCoordinates = null, currentDay = 0 } = Astro.props;

const MAPBOX_TOKEN = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

// Convert [lat, lng] (post convention) to [lng, lat] (GeoJSON convention)
const currentLngLat = currentCoordinates
  ? [currentCoordinates[1], currentCoordinates[0]]
  : null;

// Config passed to the bundled module script via a JSON <script> tag.
// We can't use `define:vars` on the script below because that forces it to be
// emitted as an inline classic script, which would break the `import 'mapbox-gl'`
// bare specifier (bare specifiers only resolve through the bundler).
const mapConfig = {
  token: MAPBOX_TOKEN,
  routeData,
  currentLngLat,
  currentDay,
};
---

<section class="map-section" aria-label="Route map">
  <div class="map-wrap">
    <div id="route-map" class="map"></div>
    <script
      type="application/json"
      id="route-map-config"
      set:html={JSON.stringify(mapConfig)}
    />

    <button
      id="map-toggle"
      class="map-toggle"
      type="button"
      aria-pressed="false"
      aria-label="Expand map"
      title="Expand map"
    >
      <svg class="icon-expand" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <path
          d="M9 1h4v4M5 13H1V9M13 1L8 6M1 13l5-5"
          stroke="currentColor"
          stroke-width="1.4"
          fill="none"
          stroke-linecap="round"
        />
      </svg>
      <svg class="icon-close" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <path
          d="M2 2l10 10M12 2L2 12"
          stroke="currentColor"
          stroke-width="1.4"
          fill="none"
          stroke-linecap="round"
        />
      </svg>
    </button>
  </div>
</section>

<link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.8.0/mapbox-gl.css" />

<style>
  .map-section {
    margin-top: 32px;
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }

  .map-wrap {
    position: relative;
    overflow: hidden;
    background: var(--surface);
  }

  .map {
    width: 100%;
    height: 55vw;
    max-height: 600px;
    min-height: 280px;
  }

  @media (min-width: 640px) {
    .map {
      height: 520px;
    }
  }

  /* Fullscreen mode — pinned to the viewport, map fills the space. */
  :global(.map-wrap.is-fullscreen) {
    position: fixed;
    inset: 0;
    z-index: 100;
    border-radius: 0;
  }

  :global(.map-wrap.is-fullscreen) .map {
    height: 100%;
    max-height: none;
    min-height: 0;
  }

  .map-toggle {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: color 150ms ease, background 150ms ease;
    z-index: 2;
  }

  .map-toggle:hover {
    color: var(--text);
  }

  .map-toggle[aria-pressed='true'] {
    color: var(--accent);
    background: var(--surface);
  }

  /* Swap icons based on toggle state */
  .map-toggle .icon-close {
    display: none;
  }

  .map-toggle[aria-pressed='true'] .icon-expand {
    display: none;
  }

  .map-toggle[aria-pressed='true'] .icon-close {
    display: block;
  }

  /* City name labels on the map — same Plus Jakarta Sans style as the rest
     of the site. Uses `:global` so Mapbox's marker wrapping doesn't scope them
     away. Each label is an HTML Marker anchored to the left of the city
     coordinate, offset to the right of the dot. */
  :global(.map-city-label) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
    color: var(--text-tertiary);
    text-shadow:
      0 0 3px rgba(26, 27, 30, 0.9),
      0 0 8px rgba(26, 27, 30, 0.7);
  }

  :global(.map-city-label.visited) {
    color: var(--accent);
  }

  :global(.map-city-label.current) {
    color: var(--text);
    font-weight: 500;
  }

  /* Pulsing current-location marker.
     Mapbox re-uses the outer element and writes an inline `transform` on it
     to position the marker. If we animate `transform` on that same element,
     the animation overwrites Mapbox's positioning and the marker gets stuck
     at (0,0) of the map. Fix: the outer `.map-current-marker` is Mapbox's
     positioning target (no animation), and an inner `.map-current-dot`
     child owns the pulse animation. */
  :global(.map-current-marker) {
    width: 14px;
    height: 14px;
    pointer-events: none;
  }

  :global(.map-current-dot) {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--accent);
    animation: map-pulse 3s ease-in-out infinite;
  }

  @keyframes map-pulse {
    0%,
    100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(184, 168, 138, 0.35);
    }
    50% {
      transform: scale(1.35);
      box-shadow: 0 0 0 8px rgba(184, 168, 138, 0.04);
    }
  }

  :global(.mapboxgl-ctrl-logo),
  :global(.mapboxgl-ctrl-attrib) {
    opacity: 0.35;
  }

</style>

<script>
  // Astro processes this through Vite as an ES module — `mapbox-gl` resolves
  // via the bundler. Keep this script free of `define:vars` so Astro doesn't
  // force it to inline (which would break bare-specifier imports).
  import mapboxgl from 'mapbox-gl';

  (async function () {
    const mapEl = document.getElementById('route-map');
    const toggle = document.getElementById('map-toggle');
    const configEl = document.getElementById('route-map-config');
    if (!mapEl || !configEl) return;

    let cfg;
    try {
      cfg = JSON.parse(configEl.textContent || '{}');
    } catch (e) {
      console.error('[RouteMap] failed to parse config', e);
      return;
    }
    const { token: MAPBOX_TOKEN, routeData, currentLngLat, currentDay } = cfg;

    if (!MAPBOX_TOKEN) {
      mapEl.innerHTML =
        '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-tertiary);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;">Map token not set</div>';
      return;
    }

    mapboxgl.accessToken = MAPBOX_TOKEN;

    // Compute bounds from all point features
    const points = routeData.features.filter(
      (f) => f.geometry.type === 'Point'
    );
    const allBounds = new mapboxgl.LngLatBounds();
    points.forEach((p) => allBounds.extend(p.geometry.coordinates));

    // Zoom to nearby region when we have a current position, full route otherwise
    const DAY_RANGE = 20;
    const nearbyPoints = currentDay
      ? points.filter(
          (p) =>
            p.properties.day >= currentDay - DAY_RANGE &&
            p.properties.day <= currentDay + DAY_RANGE
        )
      : points;
    const initialBounds = new mapboxgl.LngLatBounds();
    nearbyPoints.forEach((p) => initialBounds.extend(p.geometry.coordinates));

    const map = new mapboxgl.Map({
      container: mapEl,
      style: 'mapbox://styles/mapbox/dark-v11',
      bounds: initialBounds.isEmpty() ? allBounds : initialBounds,
      fitBoundsOptions: { padding: 60, duration: 0 },
      interactive: true,
      cooperativeGestures: true, // Ctrl/Cmd+scroll to zoom; prevents hijacking page scroll
      attributionControl: { compact: true },
    });

    const onLoad = () => {
      // Override base colors to match charcoal theme
      try {
        if (map.getLayer('background')) {
          map.setPaintProperty('background', 'background-color', '#1A1B1E');
        }
        // Water slightly lighter than bg
        const waterLayers = map.getStyle().layers.filter((l) => l.id.includes('water'));
        waterLayers.forEach((l) => {
          if (l.type === 'fill') {
            try {
              map.setPaintProperty(l.id, 'fill-color', '#242528');
            } catch (_) {}
          }
        });
        // Tone down labels heavily
        const labelLayers = map
          .getStyle()
          .layers.filter((l) => l.type === 'symbol');
        labelLayers.forEach((l) => {
          try {
            map.setLayoutProperty(l.id, 'visibility', 'none');
          } catch (_) {}
        });
      } catch (_) {
        /* style overrides are best-effort */
      }

      // Split route into visited (up to current) and future
      const routeFeature = routeData.features.find(
        (f) => f.geometry.type === 'LineString'
      );
      const visited = points.filter((p) => p.properties.day <= currentDay);
      const future = points.filter((p) => p.properties.day > currentDay);

      if (routeFeature) {
        // Full (dashed) route
        map.addSource('route-full', {
          type: 'geojson',
          data: routeFeature,
        });
        map.addLayer({
          id: 'route-full',
          type: 'line',
          source: 'route-full',
          paint: {
            'line-color': '#505258',
            'line-width': 1.8,
            'line-dasharray': [3, 3],
          },
        });

        // Visited portion (solid). Build a sliced LineString using visited
        // point coordinates in order by day.
        if (visited.length > 1) {
          const visitedCoords = visited
            .slice()
            .sort((a, b) => a.properties.day - b.properties.day)
            .map((f) => f.geometry.coordinates);
          map.addSource('route-visited', {
            type: 'geojson',
            data: {
              type: 'Feature',
              properties: {},
              geometry: { type: 'LineString', coordinates: visitedCoords },
            },
          });
          map.addLayer({
            id: 'route-visited',
            type: 'line',
            source: 'route-visited',
            paint: {
              'line-color': '#B8A88A',
              'line-width': 2,
            },
          });
        }
      }

      // Stop points
      if (future.length) {
        map.addSource('stops-future', {
          type: 'geojson',
          data: { type: 'FeatureCollection', features: future },
        });
        map.addLayer({
          id: 'stops-future',
          type: 'circle',
          source: 'stops-future',
          paint: {
            'circle-radius': 4,
            'circle-color': 'rgba(0,0,0,0)',
            'circle-stroke-color': '#505258',
            'circle-stroke-width': 1.4,
          },
        });
      }

      if (visited.length) {
        map.addSource('stops-visited', {
          type: 'geojson',
          data: { type: 'FeatureCollection', features: visited },
        });
        map.addLayer({
          id: 'stops-visited',
          type: 'circle',
          source: 'stops-visited',
          paint: {
            'circle-radius': 4,
            'circle-color': '#B8A88A',
            'circle-opacity': 0.75,
          },
        });
      }

      // Current location: pulsing HTML marker. Wrap with a positioning
      // element that Mapbox controls, and put the animation on an inner child
      // so the pulse animation doesn't clobber Mapbox's inline transform.
      if (currentLngLat) {
        const wrap = document.createElement('div');
        wrap.className = 'map-current-marker';
        const inner = document.createElement('div');
        inner.className = 'map-current-dot';
        wrap.appendChild(inner);
        new mapboxgl.Marker({ element: wrap, anchor: 'center' })
          .setLngLat(currentLngLat)
          .addTo(map);
      }

      // City name labels — HTML markers anchored left of each dot so the
      // text sits to the right of the point. Labels are styled via the
      // global `.map-city-label` rule so Plus Jakarta Sans / uppercase /
      // tracking match the rest of the site.
      points.forEach((p) => {
        const city = p.properties && p.properties.city;
        if (!city) return;
        const day = p.properties.day;

        const label = document.createElement('span');
        label.className = 'map-city-label';
        if (typeof day === 'number') {
          if (day < currentDay) label.classList.add('visited');
          else if (day === currentDay) label.classList.add('current');
        }
        label.textContent = city;

        new mapboxgl.Marker({
          element: label,
          anchor: 'left',
          offset: [8, 0],
        })
          .setLngLat(p.geometry.coordinates)
          .addTo(map);
      });
    };

    // Fire on load, or immediately if already loaded (race condition guard)
    if (map.isStyleLoaded()) {
      onLoad();
    } else {
      map.on('load', onLoad);
    }

    // Fullscreen + interaction toggle. Fullscreen pins `.map-wrap` to the
    // viewport via CSS (`.is-fullscreen`), which changes the container size,
    // so we must call `map.resize()` and refit bounds after the layout
    // change. Interaction (scroll/drag/zoom) is only meaningful in
    // fullscreen mode, so the two are coupled behind a single button.
    const wrapEl = mapEl.parentElement;
    let isFullscreen = false;

    const setFullscreen = (on) => {
      isFullscreen = on;
      if (wrapEl) wrapEl.classList.toggle('is-fullscreen', on);
      if (toggle) {
        toggle.setAttribute('aria-pressed', on ? 'true' : 'false');
        toggle.setAttribute('aria-label', on ? 'Close fullscreen' : 'Expand map');
        toggle.setAttribute('title', on ? 'Close fullscreen' : 'Expand map');
      }
      // Wait a frame for layout to settle, then tell Mapbox to re-measure.
      // Fullscreen shows the entire route; inline view focuses on the region.
      requestAnimationFrame(() => {
        map.resize();
        const b = on ? allBounds : (initialBounds.isEmpty() ? allBounds : initialBounds);
        if (!b.isEmpty()) {
          map.fitBounds(b, {
            padding: on ? 80 : 60,
            duration: 300,
          });
        }
      });
    };

    if (toggle) {
      toggle.addEventListener('click', () => setFullscreen(!isFullscreen));
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isFullscreen) setFullscreen(false);
    });
  })();
</script>
