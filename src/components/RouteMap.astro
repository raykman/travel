---
import routeData from '../data/route.json';

interface Props {
  currentCoordinates?: [number, number] | null; // [lat, lng] from latest post
  currentDay?: number;
}

const { currentCoordinates = null, currentDay = 0 } = Astro.props;

const MAPBOX_TOKEN = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

// Convert [lat, lng] (post convention) to [lng, lat] (GeoJSON/Mapbox convention)
const currentLngLat = currentCoordinates
  ? [currentCoordinates[1], currentCoordinates[0]]
  : null;

const mapConfig = {
  token: MAPBOX_TOKEN,
  routeData,
  currentLngLat,
  currentDay,
};
---

<!--
  Full-bleed map base layer.
  position: fixed, z-index: 0 — sits behind the .scroll-layer (z: 10).
  interactive: false on the Mapbox instance — flyTo works programmatically
  (driven by scrollytelling) but users cannot drag/zoom the map; page scrolls
  over it normally.

  OPTION B scaffold: to revert to a contained map on mobile, apply this CSS:
    @media (max-width: 767px) {
      .map-base { position: relative; height: 55vw; min-height: 280px; }
    }
  and in the script set `interactive: true` on mobile.
-->
<div
  class="map-base"
  role="img"
  aria-label="Interactive route map showing travel path through Japan, Vietnam, Cambodia, Laos, and Indonesia"
>
  <p class="sr-only">Route: Tokyo, Niigata, Sapporo, Kobe, Okinawa, Hanoi, Hoi An, Ho Chi Minh City, Siem Reap, Phnom Penh, Luang Prabang, Thakhek, Jakarta, Yogyakarta, Surabaya, Pangkalan Bun</p>
  <div id="route-map" class="map"></div>
  <script
    type="application/json"
    id="route-map-config"
    set:html={JSON.stringify(mapConfig)}
  />
</div>

<!-- Reset-view button — position: fixed, z: 20, above the scroll-layer -->
<button
  id="map-reset"
  class="map-reset"
  type="button"
  aria-label="Reset map to show full route"
  title="Reset view"
>
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <!-- Circular arrow (reset / refresh icon) -->
    <path d="M12.5 2.5 A6 6 0 1 0 13 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/>
    <path d="M10 0.5 L13 2.5 L10.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </svg>
</button>

<style>
  /* ---- Base layer: fixed full-viewport map ---- */
  .map-base {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    /* pointer-events: none so the scroll-layer above captures all user
       events. flyTo/fitBounds still work because they're programmatic. */
    pointer-events: none;
  }

  .map {
    width: 100%;
    height: 100%;
  }

  /* ---- Reset-view button ---- */
  .map-reset {
    position: fixed;
    bottom: calc(72px + env(safe-area-inset-bottom, 0px)); /* above back-to-top */
    right: 20px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(20, 20, 20, 0.72);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 50%;
    color: var(--text-secondary);
    /* Needs pointer-events: auto to receive clicks despite parent's none */
    pointer-events: auto;
    transition: color 150ms ease, background 150ms ease;
    z-index: 20;
    cursor: pointer;
  }

  .map-reset:hover {
    color: var(--text);
    background: rgba(35, 35, 35, 0.88);
  }

  /* ---- Map city labels (HTML Markers) ---- */
  :global(.map-city-label) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
    color: var(--text-tertiary);
    text-shadow:
      0 0 3px rgba(16, 16, 15, 0.95),
      0 0 10px rgba(16, 16, 15, 0.8);
  }

  :global(.map-city-label.visited) {
    color: var(--accent);
  }

  :global(.map-city-label.current) {
    color: var(--text);
    font-weight: 500;
  }

  /* ---- Current-location pulsing marker ---- */
  :global(.map-current-marker) {
    width: 14px;
    height: 14px;
    pointer-events: none;
  }

  :global(.map-current-dot) {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--accent);
    animation: map-pulse 3s ease-in-out infinite;
  }

  @keyframes map-pulse {
    0%,
    100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(184, 168, 138, 0.35);
    }
    50% {
      transform: scale(1.35);
      box-shadow: 0 0 0 8px rgba(184, 168, 138, 0.04);
    }
  }

  :global(.mapboxgl-ctrl-logo),
  :global(.mapboxgl-ctrl-attrib) {
    opacity: 0.25;
  }
</style>

<script>
  import mapboxgl from 'mapbox-gl';

  (async function () {
    const mapEl = document.getElementById('route-map');
    const resetBtn = document.getElementById('map-reset');
    const configEl = document.getElementById('route-map-config');
    if (!mapEl || !configEl) return;

    let cfg: any;
    try {
      cfg = JSON.parse(configEl.textContent || '{}');
    } catch (e) {
      console.error('[RouteMap] failed to parse config', e);
      return;
    }
    const { token: MAPBOX_TOKEN, routeData, currentLngLat, currentDay } = cfg;

    if (!MAPBOX_TOKEN) {
      mapEl.innerHTML =
        '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-tertiary);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;">Map token not set</div>';
      return;
    }

    mapboxgl.accessToken = MAPBOX_TOKEN;

    // ---- Route data helpers ----
    const departurePoint = routeData.features.find(
      (f: any) => f.geometry.type === 'Point' && f.properties.departure
    );
    const points = routeData.features.filter(
      (f: any) => f.geometry.type === 'Point' && !f.properties.departure
    );
    const routeFeatureByName = (name: string) =>
      routeData.features.find(
        (f: any) => f.geometry.type === 'LineString' && f.properties.name === name
      );

    const allBounds = new mapboxgl.LngLatBounds();
    points.forEach((p: any) => allBounds.extend(p.geometry.coordinates));

    const DAY_RANGE = 20;
    const nearbyPoints = currentDay
      ? points.filter(
          (p: any) =>
            p.properties.day >= currentDay - DAY_RANGE &&
            p.properties.day <= currentDay + DAY_RANGE
        )
      : points;
    const initialBounds = new mapboxgl.LngLatBounds();
    nearbyPoints.forEach((p: any) => initialBounds.extend(p.geometry.coordinates));

    // ---- Map init ----
    // interactive: false — programmatic flyTo works but user can't drag/zoom.
    // This keeps page scrolling clean; scrollytelling drives the map.
    const map = new mapboxgl.Map({
      container: mapEl,
      style: 'mapbox://styles/mapbox/dark-v11',
      bounds: initialBounds.isEmpty() ? allBounds : initialBounds,
      fitBoundsOptions: { padding: 100, duration: 0 },
      interactive: false,
      attributionControl: { compact: true },
    });

    // Expose for scrollytelling + reset button
    (window as any).__map = map;
    (window as any).__mapAllBounds = allBounds;

    // ---- Layer setup ----
    const onLoad = () => {
      // Override base colors to match deep charcoal theme
      try {
        if (map.getLayer('background')) {
          map.setPaintProperty('background', 'background-color', '#10100F');
        }
        const waterLayers = map.getStyle().layers.filter((l: any) => l.id.includes('water'));
        waterLayers.forEach((l: any) => {
          if (l.type === 'fill') {
            try { map.setPaintProperty(l.id, 'fill-color', '#181818'); } catch (_) {}
          }
        });
        const labelLayers = map.getStyle().layers.filter((l: any) => l.type === 'symbol');
        labelLayers.forEach((l: any) => {
          try { map.setLayoutProperty(l.id, 'visibility', 'none'); } catch (_) {}
        });
      } catch (_) { /* style overrides are best-effort */ }

      // ---- Departure flight arc (SF → Tokyo) ----
      const departureFlight = routeFeatureByName('departure-flight');
      const flightIsVisited = currentDay > 0;
      if (departureFlight) {
        map.addSource('departure-flight', { type: 'geojson', data: departureFlight });
        map.addLayer({
          id: 'departure-flight',
          type: 'line',
          source: 'departure-flight',
          paint: flightIsVisited
            ? { 'line-color': '#B8A88A', 'line-width': 2, 'line-dasharray': [0.001, 5000] }
            : { 'line-color': '#505258', 'line-width': 1.8, 'line-dasharray': [3, 3] },
        });

        if (flightIsVisited) {
          const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!prefersReduced) {
            const DASH_MAX = 5000;
            const DURATION = 3000;
            const startTime = performance.now();
            function animateFlight(now: number) {
              const t = Math.min((now - startTime) / DURATION, 1);
              const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
              const drawn = Math.max(DASH_MAX * ease, 0.001);
              const gap = Math.max(DASH_MAX - drawn, 0.001);
              try { map.setPaintProperty('departure-flight', 'line-dasharray', [drawn, gap]); } catch (_) {}
              if (t < 1) requestAnimationFrame(animateFlight);
            }
            requestAnimationFrame(animateFlight);
          } else {
            try { map.setPaintProperty('departure-flight', 'line-dasharray', [5000, 0]); } catch (_) {}
          }
        }
      }

      // Departure city dot + label
      if (departurePoint) {
        map.addSource('stop-departure', {
          type: 'geojson',
          data: { type: 'FeatureCollection', features: [departurePoint] },
        });
        map.addLayer({
          id: 'stop-departure',
          type: 'circle',
          source: 'stop-departure',
          paint: flightIsVisited
            ? { 'circle-radius': 4, 'circle-color': '#B8A88A', 'circle-opacity': 0.75 }
            : { 'circle-radius': 4, 'circle-color': 'rgba(0,0,0,0)', 'circle-stroke-color': '#505258', 'circle-stroke-width': 1.4 },
        });
        const depLabel = document.createElement('span');
        depLabel.className = 'map-city-label';
        depLabel.textContent = departurePoint.properties.city;
        new mapboxgl.Marker({ element: depLabel, anchor: 'left', offset: [8, 0] })
          .setLngLat(departurePoint.geometry.coordinates)
          .addTo(map);
      }

      // ---- Route lines ----
      const routeFeature = routeFeatureByName('route');
      const visited = points.filter((p: any) => p.properties.day <= currentDay);
      const future = points.filter((p: any) => p.properties.day > currentDay);

      if (routeFeature) {
        map.addSource('route-full', { type: 'geojson', data: routeFeature });
        map.addLayer({
          id: 'route-full',
          type: 'line',
          source: 'route-full',
          paint: { 'line-color': '#505258', 'line-width': 1.8, 'line-dasharray': [3, 3] },
        });

        if (visited.length > 1) {
          const visitedCoords = visited
            .slice()
            .sort((a: any, b: any) => a.properties.day - b.properties.day)
            .map((f: any) => f.geometry.coordinates);
          map.addSource('route-visited', {
            type: 'geojson',
            data: { type: 'Feature', properties: {}, geometry: { type: 'LineString', coordinates: visitedCoords } },
          });
          map.addLayer({
            id: 'route-visited',
            type: 'line',
            source: 'route-visited',
            paint: { 'line-color': '#B8A88A', 'line-width': 2, 'line-dasharray': [0.001, 5000] },
          });

          const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!prefersReduced) {
            const DASH_MAX = 5000;
            const DURATION = 3000;
            const startTime = performance.now();
            function animateRoute(now: number) {
              const t = Math.min((now - startTime) / DURATION, 1);
              const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
              const drawn = Math.max(DASH_MAX * ease, 0.001);
              const gap = Math.max(DASH_MAX - drawn, 0.001);
              try { map.setPaintProperty('route-visited', 'line-dasharray', [drawn, gap]); } catch (_) {}
              if (t < 1) requestAnimationFrame(animateRoute);
            }
            requestAnimationFrame(animateRoute);
          } else {
            try { map.setPaintProperty('route-visited', 'line-dasharray', [5000, 0]); } catch (_) {}
          }
        }
      }

      // ---- Stop dots ----
      if (future.length) {
        map.addSource('stops-future', { type: 'geojson', data: { type: 'FeatureCollection', features: future } });
        map.addLayer({
          id: 'stops-future', type: 'circle', source: 'stops-future',
          paint: { 'circle-radius': 4, 'circle-color': 'rgba(0,0,0,0)', 'circle-stroke-color': '#505258', 'circle-stroke-width': 1.4 },
        });
      }

      if (visited.length) {
        map.addSource('stops-visited', { type: 'geojson', data: { type: 'FeatureCollection', features: visited } });
        map.addLayer({
          id: 'stops-visited', type: 'circle', source: 'stops-visited',
          paint: { 'circle-radius': 4, 'circle-color': '#B8A88A', 'circle-opacity': 0.75 },
        });
      }

      // ---- Current location pulsing marker ----
      if (currentLngLat) {
        const wrap = document.createElement('div');
        wrap.className = 'map-current-marker';
        const inner = document.createElement('div');
        inner.className = 'map-current-dot';
        wrap.appendChild(inner);
        new mapboxgl.Marker({ element: wrap, anchor: 'center' })
          .setLngLat(currentLngLat)
          .addTo(map);
      }

      // ---- City name labels ----
      points.forEach((p: any) => {
        const city = p.properties?.city;
        if (!city) return;
        const day = p.properties.day;
        const label = document.createElement('span');
        label.className = 'map-city-label';
        if (typeof day === 'number') {
          if (day < currentDay) label.classList.add('visited');
          else if (day === currentDay) label.classList.add('current');
        }
        label.textContent = city;
        new mapboxgl.Marker({ element: label, anchor: 'left', offset: [8, 0] })
          .setLngLat(p.geometry.coordinates)
          .addTo(map);
      });

      // Signal readiness for scrollytelling
      document.dispatchEvent(new CustomEvent('mapready'));
    };

    if (map.isStyleLoaded()) {
      onLoad();
    } else {
      map.on('load', onLoad);
    }

    // ---- Reset-view button ----
    resetBtn?.addEventListener('click', () => {
      const b = allBounds.isEmpty() ? null : allBounds;
      if (b) {
        map.flyTo({
          ...map.cameraForBounds(b, { padding: 100 })!,
          duration: 1400,
          essential: true,
        });
      }
    });
  })();
</script>
