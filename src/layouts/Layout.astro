---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Where Is Ray',
  description = 'Following a 79-day trip through Asia',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Theme / PWA -->
    <meta name="theme-color" content="#1A1B1E" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Ray" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="icon" type="image/png" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- OG tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://whereisray.com/og-image.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://whereisray.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://whereisray.com/og-image.png" />

    <!-- Fonts: Plus Jakarta Sans (300, 400, 500) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Mapbox GL CSS (loaded here to avoid flash of unstyled map) -->
    <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.8.0/mapbox-gl.css" />
  </head>
  <body class="immersive">
    <slot />

    <!-- Global image lightbox — shown by dispatching 'lightbox:open' with { images:[{src,alt}], index } -->
    <div id="lightbox" class="lightbox" hidden role="dialog" aria-modal="true" aria-label="Full screen image">
      <button id="lightbox-close" class="lightbox-close" aria-label="Close fullscreen">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
      <button id="lightbox-prev" class="lightbox-nav lightbox-prev" aria-label="Previous image">
        <svg width="10" height="18" viewBox="0 0 10 18" fill="none" aria-hidden="true">
          <path d="M9 1L1 9l8 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <img id="lightbox-img" class="lightbox-img" src="" alt="" />
      <button id="lightbox-next" class="lightbox-nav lightbox-next" aria-label="Next image">
        <svg width="10" height="18" viewBox="0 0 10 18" fill="none" aria-hidden="true">
          <path d="M1 1l8 8-8 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div id="lightbox-dots" class="lightbox-dots" aria-hidden="true"></div>
    </div>
  </body>
</html>

<style is:global>
  /* ---- Global lightbox ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 300;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    cursor: zoom-out;
    animation: lb-in 180ms ease;
  }

  .lightbox[hidden] {
    display: none;
  }

  @keyframes lb-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 8px;
    cursor: default;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.6);
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.10);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    transition: background 150ms ease;
    z-index: 1;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.20);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.10);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    transition: background 150ms ease;
    z-index: 1;
  }

  .lightbox-nav:hover { background: rgba(255, 255, 255, 0.20); }
  .lightbox-nav[hidden] { display: none; }
  .lightbox-prev { left: 20px; }
  .lightbox-next { right: 20px; }

  .lightbox-dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
  }

  .lightbox-dots[hidden] { display: none; }

  .lightbox-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    transition: background 150ms ease, transform 150ms ease;
  }

  .lightbox-dot.active {
    background: #fff;
    transform: scale(1.25);
  }
</style>

<script is:inline>
  (function () {
    const lb       = document.getElementById('lightbox');
    const img      = document.getElementById('lightbox-img');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn  = document.getElementById('lightbox-prev');
    const nextBtn  = document.getElementById('lightbox-next');
    const dotsEl   = document.getElementById('lightbox-dots');
    if (!lb || !img) return;

    let lbImages = [];
    let lbIndex  = 0;

    function buildDots() {
      dotsEl.innerHTML = '';
      lbImages.forEach((_, i) => {
        const d = document.createElement('span');
        d.className = 'lightbox-dot' + (i === lbIndex ? ' active' : '');
        dotsEl.appendChild(d);
      });
    }

    function updateNav() {
      const multi = lbImages.length > 1;
      prevBtn.toggleAttribute('hidden', !multi || lbIndex === 0);
      nextBtn.toggleAttribute('hidden', !multi || lbIndex === lbImages.length - 1);
      dotsEl.toggleAttribute('hidden', !multi);
      if (multi) {
        dotsEl.querySelectorAll('.lightbox-dot').forEach((d, i) =>
          d.classList.toggle('active', i === lbIndex)
        );
      }
    }

    function show(index) {
      lbIndex = index;
      const { src, alt } = lbImages[lbIndex];
      img.src = src;
      img.alt = alt || '';
      updateNav();
    }

    function open(images, index) {
      lbImages = images;
      buildDots();
      show(index);
      lb.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lb.setAttribute('hidden', '');
      img.src = '';
      lbImages = [];
      document.body.style.overflow = '';
    }

    // Triggered by PhotoCard expand buttons
    document.addEventListener('lightbox:open', (e) => {
      const images = e.detail.images || [{ src: e.detail.src, alt: e.detail.alt || '' }];
      open(images, e.detail.index ?? 0);
    });

    prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); if (lbIndex > 0) show(lbIndex - 1); });
    nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); if (lbIndex < lbImages.length - 1) show(lbIndex + 1); });
    closeBtn?.addEventListener('click', close);

    // Click backdrop to close
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (lb.hasAttribute('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft' && lbIndex > 0) show(lbIndex - 1);
      if (e.key === 'ArrowRight' && lbIndex < lbImages.length - 1) show(lbIndex + 1);
    });
  })();
</script>
