---
import Layout from '../layouts/Layout.astro';
import PasswordGate from '../components/PasswordGate.astro';
import StatusHero from '../components/StatusHero.astro';
import ProgressBar from '../components/ProgressBar.astro';
import RouteMap from '../components/RouteMap.astro';
import Countdown from '../components/Countdown.astro';
import PhotoFeed from '../components/PhotoFeed.astro';
import UpcomingSchedule from '../components/UpcomingSchedule.astro';
import Footer from '../components/Footer.astro';

import { getAllPosts } from '../lib/posts';
import {
  getTripState,
  getCurrentDay,
  TRIP_LENGTH_DAYS,
} from '../lib/dates';
import countries from '../data/countries.json';

const state = getTripState();
const currentDay = state === 'pre' ? 0 : getCurrentDay();

const posts = await getAllPosts();
const latest = posts[0];

const latestCountry = latest
  ? countries.find((c) => c.id === latest.data.country)
  : undefined;

const headerLine =
  state === 'live'
    ? `Day ${currentDay}`
    : state === 'post'
      ? `${TRIP_LENGTH_DAYS} days · 5 countries`
      : '2026';

const buildTime = new Date().toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit',
  timeZone: 'Asia/Bangkok',
});

const postStats = state === 'post' && posts.length > 0 ? {
  count: posts.length,
  countryCount: new Set(posts.map((p) => p.data.country)).size,
  cityCount: new Set(posts.map((p) => p.data.location)).size,
} : null;
---

<Layout>
  <PasswordGate />

  <!--
    IMMERSIVE LAYOUT STRUCTURE
    ═══════════════════════════
    z-index stack (bottom → top):
      0   .map-base          (RouteMap — position: fixed, full viewport)
      10  .scroll-layer      (all visible content, scrolls over the map)
      15  .site-header       (sticky glass bar at the top of scroll-layer)
      20  #map-reset         (reset-view button in RouteMap)
      20  #back-to-top       (back-to-top button)
     100  #password-gate     (PasswordGate overlay)

    Mobile scaffold → see global.css "Immersive layout scaffold" comment block.
  -->

  <!-- Base layer: full-bleed fixed map -->
  <RouteMap
    currentCoordinates={latest?.data.coordinates ?? null}
    currentDay={currentDay}
  />

  <!-- Scrollable content layer — rides over the map -->
  <div class="scroll-layer">

    <!-- Sticky glass header -->
    <header class="site-header glass" aria-label="Site header">
      <h1 class="site-title">Where Is Ray</h1>
      <span class="header-meta">{headerLine}</span>
    </header>

    {state === 'pre' ? (
      <!-- PRE-TRIP STATE -->
      <div class="hero-zone">
        <Countdown />

        <p class="intro-text">
          Japan, Vietnam, Cambodia, Laos, and Indonesia.<br />
          Check back once the trip starts for live updates.
        </p>

        <!-- Country list with scrollytelling data-lnglat attributes -->
        <section class="countries-panel glass" aria-label="Itinerary">
          <ul class="country-list">
            {countries.map((c) => (
              <li
                class="country-row"
                data-lnglat={`${c.center[0]},${c.center[1]}`}
              >
                <span class="country-flag" aria-hidden="true">{c.flag}</span>
                <span class="country-name" style={`color: ${c.color};`}>{c.name}</span>
                <span class="country-dates">
                  {new Date(c.startDate).toLocaleDateString('en-US', {
                    month: 'short', day: 'numeric', timeZone: 'UTC',
                  })}{' – '}
                  {new Date(c.endDate).toLocaleDateString('en-US', {
                    month: 'short', day: 'numeric', timeZone: 'UTC',
                  })}
                </span>
              </li>
            ))}
          </ul>
        </section>
      </div>
    ) : (
      <!-- LIVE / POST-TRIP STATE -->
      <>
        <div class="hero-zone">
          <StatusHero
            state={state}
            city={latest?.data.location}
            flag={latestCountry?.flag}
            countryName={latestCountry?.name}
          />

          {postStats && (
            <p class="post-trip-stats glass">
              {postStats.count} posts · {postStats.countryCount} countries · {postStats.cityCount} cities
            </p>
          )}

          <ProgressBar currentDay={currentDay} />

          {state === 'live' && <UpcomingSchedule />}
        </div>

        <!-- Field notes feed — full-width, no container constraint -->
        <div class="feed-zone">
          <PhotoFeed posts={posts} />
        </div>
      </>
    )}

    <Footer buildTime={buildTime} />
  </div>

  <!-- Fixed UI above scroll layer -->
  <button id="back-to-top" class="back-to-top" aria-label="Back to top">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M7 12V2M2 7l5-5 5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</Layout>

<!-- ─── Scrollytelling ─────────────────────────────────────────────────────
  Watches [data-lnglat] elements (photo cards + pre-trip country rows).
  When an element reaches ~30% from the top of the viewport, flyTo its
  coordinates on the background Mapbox map.

  Zoom levels:
    z9  — country-level view (pre-trip country rows)
    z10 — city-level view   (field notes photo cards)

  The observer starts after the 'mapready' event to avoid racing the
  map initialization. If the map is already ready (fast connection),
  it starts immediately.
──────────────────────────────────────────────────────────────────────────── -->
<script>
  // ---- Back-to-top ----
  const btn = document.getElementById('back-to-top');
  if (btn) {
    window.addEventListener('scroll', () => {
      const show = window.scrollY > window.innerHeight;
      btn.style.opacity = show ? '1' : '0';
      btn.style.pointerEvents = show ? 'auto' : 'none';
    }, { passive: true });
    btn.addEventListener('click', () => {
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: reducedMotion ? 'instant' : 'smooth' });
    });
  }

  // ---- Scrollytelling ----
  function initScrollytelling() {
    const map = (window as any).__map;
    if (!map) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // All elements that should trigger a map flyTo on scroll
    const targets = document.querySelectorAll<HTMLElement>('[data-lnglat]');
    if (!targets.length || prefersReduced) return;

    // Debounce: only one flyTo per 800ms to avoid spamming the camera
    let flyTimeout: ReturnType<typeof setTimeout> | null = null;
    let lastLngLat = '';

    const observer = new IntersectionObserver(
      (entries) => {
        // Find the entry that's most prominently in view
        const active = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (!active) return;

        const raw = (active.target as HTMLElement).dataset.lnglat;
        if (!raw || raw === lastLngLat) return;
        lastLngLat = raw;

        const [lngStr, latStr] = raw.split(',');
        const center: [number, number] = [parseFloat(lngStr), parseFloat(latStr)];
        if (isNaN(center[0]) || isNaN(center[1])) return;

        // Determine zoom: country rows get z9, photo cards get z10
        const isCountryRow = active.target.classList.contains('country-row');
        const zoom = isCountryRow ? 7 : 10;

        if (flyTimeout) clearTimeout(flyTimeout);
        flyTimeout = setTimeout(() => {
          map.flyTo({
            center,
            zoom,
            duration: prefersReduced ? 0 : 1800,
            essential: true,
            curve: 1.4,
          });
        }, 80); // small debounce to let scroll settle
      },
      {
        // Trigger when element crosses 30% from the top of the viewport
        rootMargin: '-30% 0px -40% 0px',
        threshold: 0,
      }
    );

    targets.forEach((el) => observer.observe(el));
  }

  // Start after map signals readiness, or immediately if already ready
  if ((window as any).__map) {
    initScrollytelling();
  } else {
    document.addEventListener('mapready', initScrollytelling, { once: true });
  }
</script>

<style>
  /* ── Scroll layer ── */
  .scroll-layer {
    position: relative;
    z-index: 10;
    /* Enough top padding so the hero zone content clears the sticky header */
    padding-top: 0;
  }

  /* ── Sticky glass header ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 15;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px var(--content-pad);
    border-radius: 0; /* full-width bar — no rounded top corners */
    border-top: none;
    border-left: none;
    border-right: none;
    gap: 16px;
  }

  .site-title {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .header-meta {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  /* ── Hero zone: first-viewport glass panels ── */
  .hero-zone {
    min-height: calc(100svh - 52px); /* full viewport minus header height */
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    padding: 32px var(--content-pad) 40px;
    max-width: min(600px, 100%);
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  /* ── Pre-trip: intro text ── */
  .intro-text {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-secondary);
    text-align: center;
    margin: 0;
  }

  /* ── Pre-trip: country list panel ── */
  .countries-panel {
    padding: 4px 0;
  }

  .country-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .country-row {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    cursor: default;
    transition: background 200ms ease;
  }

  .country-row:last-child {
    border-bottom: none;
  }

  .country-row:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .country-flag {
    font-size: 18px;
    line-height: 1;
  }

  .country-name {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .country-dates {
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  /* ── Post-trip stats ── */
  .post-trip-stats {
    text-align: center;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin: 0;
    padding: 12px 20px;
    border-radius: 999px; /* pill */
    align-self: center;
  }

  /* ── Field notes zone ── */
  .feed-zone {
    /* Subtle top gap so the hero zone has clear visual separation */
    padding-top: 48px;
  }

  /* ── Back-to-top ── */
  .back-to-top {
    position: fixed;
    bottom: calc(20px + env(safe-area-inset-bottom, 0px));
    right: 20px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(20, 20, 20, 0.72);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 50%;
    color: var(--text-secondary);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease, color 150ms ease;
    z-index: 20;
  }

  .back-to-top:hover {
    color: var(--text);
  }
</style>
